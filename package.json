{
  "name": "stanford-compilers-lab-website",
  "type": "module",
  "version": "1.0.0",
  "private": true,
  "description": "Website for Fredrik Kjolstad's research group in the Stanford Department of Computer Science.",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=20.11.0"
  },
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "check": "astro check",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "validate:content": "tsx scripts/validate-content.ts",
    "check:links": "tsx scripts/check-links.ts",
    "import:legacy": "tsx scripts/import-legacy-content.ts",
    "generate:assets": "tsx scripts/generate-assets.ts",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:install": "playwright install",
    "verify": "pnpm run format:check && pnpm run lint && pnpm run validate:content && pnpm run check && pnpm run test:unit && pnpm run build && pnpm run check:links"
  },
  "dependencies": {
    "astro": "^5.13.0"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.4",
    "@astrojs/sitemap": "^3.4.0",
    "@axe-core/playwright": "^4.10.1",
    "@playwright/test": "^1.55.0",
    "@typescript-eslint/parser": "^8.20.0",
    "axe-core": "^4.10.2",
    "eslint": "^9.18.0",
    "eslint-plugin-astro": "^1.3.1",
    "prettier": "^3.4.2",
    "prettier-plugin-astro": "^0.14.1",
    "sharp": "^0.34.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^3.0.0",
    "yaml": "^2.6.1"
  }
}
