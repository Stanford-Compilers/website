---
import { Image } from 'astro:assets';
import Icon from '../ui/Icon.astro';
import { initials, monogramHue } from '../../lib/people';
import type { Person } from '../../lib/collections';

interface Props {
  person: Person;
  headingLevel?: 2 | 3;
}
const { person, headingLevel = 3 } = Astro.props;
const Heading = `h${headingLevel}` as 'h2' | 'h3';

const primaryHref = person.hasDetail
  ? `/people/${person.id}`
  : (person.website ?? person.linkedin ?? undefined);
const primaryExternal = !person.hasDetail && Boolean(primaryHref);

const profiles = [
  person.website &&
    person.website !== primaryHref && { href: person.website, icon: 'external', label: 'Website' },
  person.github && { href: person.github, icon: 'github', label: 'GitHub' },
  person.scholar && { href: person.scholar, icon: 'scholar', label: 'Google Scholar' },
  person.orcid && { href: person.orcid, icon: 'orcid', label: 'ORCID' },
  person.linkedin &&
    person.linkedin !== primaryHref && {
      href: person.linkedin,
      icon: 'linkedin',
      label: 'LinkedIn',
    },
].filter(Boolean) as { href: string; icon: string; label: string }[];

const hue = monogramHue(person.name);
---

<article class="person" style={`--mono-h:${hue}`}>
  <div class="person__ring">
    {
      person.portrait ? (
        <Image
          src={person.portrait}
          alt={person.portraitAlt ?? `Portrait of ${person.name}`}
          width={320}
          height={320}
          class="person__photo"
        />
      ) : (
        <div class="monogram" aria-hidden="true">
          <span class="monogram__bracket monogram__bracket--l">[</span>
          <span class="monogram__initials">{initials(person.name)}</span>
          <span class="monogram__bracket monogram__bracket--r">]</span>
        </div>
      )
    }
  </div>

  <div class="person__body">
    <Heading class="person__name">
      {
        primaryHref ? (
          <a
            href={primaryHref}
            class="person__name-link"
            {...(primaryExternal ? { rel: 'noopener noreferrer' } : {})}
          >
            {person.name}
          </a>
        ) : (
          person.name
        )
      }
    </Heading>
    <p class="person__role">{person.role}</p>
    {
      person.coadvisors.length > 0 && (
        <p class="person__coadvise subtle">
          with {person.coadvisors.map((c) => c.name).join(', ')}
        </p>
      )
    }
    {person.destination && <p class="person__dest">→ {person.destination}</p>}

    {
      profiles.length > 0 && (
        <ul class="person__profiles">
          {profiles.map((p) => (
            <li>
              <a href={p.href} rel="noopener noreferrer" aria-label={`${person.name} — ${p.label}`}>
                <Icon name={p.icon} size={18} />
              </a>
            </li>
          ))}
        </ul>
      )
    }
  </div>
</article>

<style>
  .person {
    --photo: 150px;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    height: 100%;
    padding: var(--space-l) var(--space-m) var(--space-m);
    border: 1px solid var(--line);
    border-radius: var(--radius-l);
    background: var(--surface);
    transition:
      border-color var(--dur-2) var(--ease),
      box-shadow var(--dur-2) var(--ease);
  }
  .person:hover {
    border-color: var(--line-strong);
    box-shadow: var(--shadow-2);
  }
  .person__ring {
    flex: 0 0 auto;
    width: calc(var(--photo) + 10px);
    height: calc(var(--photo) + 10px);
    padding: 4px;
    border-radius: 50%;
    background: var(--surface);
    border: 1px solid var(--accent-line);
  }
  .person__photo,
  .monogram {
    width: var(--photo);
    height: var(--photo);
    border-radius: 50%;
    object-fit: cover;
  }
  .monogram {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.05em;
    background: hsl(var(--mono-h) 26% 93%);
    color: var(--ink-muted);
    font-family: var(--font-mono);
  }
  .monogram__initials {
    font-size: calc(var(--photo) * 0.32);
    font-weight: 500;
    letter-spacing: 0.02em;
    color: var(--ink);
  }
  .monogram__bracket {
    color: var(--accent);
    font-size: calc(var(--photo) * 0.38);
    line-height: 1;
    opacity: 0.7;
  }
  .person__body {
    min-width: 0;
    width: 100%;
    flex: 1 1 auto;
    margin-top: var(--space-s);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.15rem;
  }
  .person__name {
    font-family: var(--font-display);
    font-optical-sizing: auto;
    font-size: var(--step-1);
    font-weight: 500;
    letter-spacing: -0.005em;
    line-height: 1.15;
  }
  .person__name-link {
    color: var(--ink);
    text-decoration: none;
  }
  .person__name-link:hover {
    color: var(--accent);
  }
  .person__role {
    font-size: var(--step--1);
    color: var(--ink-muted);
    margin-top: 0.4rem;
  }
  .person__coadvise,
  .person__dest {
    font-size: var(--step--2);
  }
  .person__dest {
    font-family: var(--font-mono);
    color: var(--tech);
    margin-top: 0.35rem;
  }
  .person__profiles {
    list-style: none;
    display: flex;
    justify-content: center;
    gap: 0.55rem;
    padding: 0.7rem 0 0;
    margin: auto 0 0; /* pin icon row to the card bottom so all cards align */
  }
  .person__profiles a {
    display: inline-flex;
    color: var(--ink-subtle);
    padding: 0.15rem;
    border-radius: var(--radius-xs);
  }
  .person__profiles a:hover {
    color: var(--accent);
  }

  :global(:root[data-theme='dark']) .monogram {
    background: hsl(var(--mono-h) 15% 17%);
  }
</style>
