---
/**
 * Inline SVG icon system. Icons are decorative by default (aria-hidden).
 * Pass `label` to give an icon an accessible name (role="img").
 */
interface Props {
  name: string;
  size?: number;
  label?: string;
  class?: string;
  stroke?: number;
}

const { name, size = 20, label, class: className, stroke = 1.6 } = Astro.props;

// Two icon styles: stroke-based (geometric) and fill-based (brand marks).
const STROKE: Record<string, string> = {
  'arrow-right': '<path d="M5 12h14M13 6l6 6-6 6"/>',
  'arrow-up-right': '<path d="M7 17 17 7M8 7h9v9"/>',
  external:
    '<path d="M14 4h6v6M20 4l-9 9M18 14v5a1 1 0 0 1-1 1H5a1 1 0 0 1-1-1V7a1 1 0 0 1 1-1h5"/>',
  search: '<circle cx="11" cy="11" r="7"/><path d="m20 20-3.2-3.2"/>',
  close: '<path d="M6 6l12 12M18 6 6 18"/>',
  menu: '<path d="M3 6h18M3 12h18M3 18h18"/>',
  filter: '<path d="M3 5h18l-7 8v6l-4-2v-4z"/>',
  'chevron-down': '<path d="m6 9 6 6 6-6"/>',
  check: '<path d="M4 12l5 5L20 6"/>',
  plus: '<path d="M12 5v14M5 12h14"/>',
  sun: '<circle cx="12" cy="12" r="4"/><path d="M12 2v2M12 20v2M2 12h2M20 12h2M4.9 4.9l1.4 1.4M17.7 17.7l1.4 1.4M4.9 19.1l1.4-1.4M17.7 6.3l1.4-1.4"/>',
  moon: '<path d="M20 14.5A8 8 0 1 1 9.5 4a6.5 6.5 0 0 0 10.5 10.5z"/>',
  mail: '<rect x="3" y="5" width="18" height="14" rx="2"/><path d="m3 7 9 6 9-6"/>',
  pdf: '<path d="M14 3H6a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V9z"/><path d="M14 3v6h6"/>',
  doi: '<circle cx="12" cy="12" r="9"/><path d="M12 8v8M9 12h6"/>',
  code: '<path d="m8 8-4 4 4 4M16 8l4 4-4 4M13 5l-2 14"/>',
  project:
    '<circle cx="12" cy="12" r="9"/><path d="M3 12h18M12 3c2.5 2.5 3.8 5.7 3.8 9S14.5 18.5 12 21c-2.5-2.5-3.8-5.7-3.8-9S9.5 5.5 12 3z"/>',
  video: '<rect x="3" y="5" width="18" height="14" rx="2"/><path d="m10 9 5 3-5 3z"/>',
  quote:
    '<path d="M8 5H4a1 1 0 0 0-1 1v5a1 1 0 0 0 1 1h4M8 5v11a3 3 0 0 1-3 3M20 5h-4a1 1 0 0 0-1 1v5a1 1 0 0 0 1 1h4M20 5v11a3 3 0 0 1-3 3"/>',
  copy: '<rect x="9" y="9" width="11" height="11" rx="2"/><path d="M5 15V5a2 2 0 0 1 2-2h8"/>',
  book: '<path d="M4 5a2 2 0 0 1 2-2h13v16H6a2 2 0 0 0-2 2z"/><path d="M4 19a2 2 0 0 1 2-2h13"/>',
  chip: '<rect x="7" y="7" width="10" height="10" rx="1.5"/><path d="M10 2v3M14 2v3M10 19v3M14 19v3M2 10h3M2 14h3M19 10h3M19 14h3"/>',
  layers: '<path d="m12 3 9 5-9 5-9-5z"/><path d="m3 13 9 5 9-5"/>',
  users:
    '<circle cx="9" cy="8" r="3.2"/><path d="M3.5 20a5.5 5.5 0 0 1 11 0"/><path d="M16 5.2a3.2 3.2 0 0 1 0 5.6M17 20a5.5 5.5 0 0 0-2.6-4.7"/>',
  compass: '<circle cx="12" cy="12" r="9"/><path d="m15.5 8.5-2 5-5 2 2-5z"/>',
};

const FILL: Record<string, string> = {
  github:
    '<path d="M12 1.5a10.5 10.5 0 0 0-3.32 20.47c.53.1.72-.23.72-.5v-1.76c-2.93.64-3.55-1.41-3.55-1.41-.48-1.22-1.17-1.55-1.17-1.55-.96-.65.07-.64.07-.64 1.06.08 1.62 1.09 1.62 1.09.94 1.61 2.47 1.15 3.07.88.1-.68.37-1.15.67-1.41-2.34-.27-4.8-1.17-4.8-5.2 0-1.15.41-2.09 1.08-2.83-.11-.27-.47-1.34.1-2.8 0 0 .88-.28 2.88 1.08a10 10 0 0 1 5.24 0c2-1.36 2.88-1.08 2.88-1.08.57 1.46.21 2.53.1 2.8.67.74 1.08 1.68 1.08 2.83 0 4.04-2.47 4.93-4.82 5.19.38.33.72.97.72 1.96v2.9c0 .28.19.61.73.5A10.5 10.5 0 0 0 12 1.5z"/>',
  scholar:
    '<path d="M12 2 1 8.5l11 6.5 9-5.32V16h2V8.5z"/><path d="M5 12.7V17c0 1.9 3.1 3.8 7 3.8s7-1.9 7-3.8v-4.3l-7 4.1z"/>',
  orcid:
    '<path d="M12 2a10 10 0 1 0 0 20 10 10 0 0 0 0-20zM8.1 7.6a.85.85 0 1 1 0 1.7.85.85 0 0 1 0-1.7zM7.3 10.5h1.6v6.9H7.3zM11 10.5h3.1c2.9 0 4.2 2.1 4.2 3.5 0 1.5-1.2 3.4-4.2 3.4H11zm1.6 1.4v4h1.4c1.9 0 2.6-1 2.6-2s-.8-2-2.7-2z"/>',
  linkedin:
    '<path d="M20.4 3H3.6A.6.6 0 0 0 3 3.6v16.8a.6.6 0 0 0 .6.6h16.8a.6.6 0 0 0 .6-.6V3.6a.6.6 0 0 0-.6-.6zM8.3 18.3H5.4V9.7h2.9zM6.9 8.4a1.7 1.7 0 1 1 0-3.4 1.7 1.7 0 0 1 0 3.4zm11.4 9.9h-2.9v-4.2c0-1 0-2.3-1.4-2.3s-1.6 1.1-1.6 2.2v4.3H9.5V9.7h2.8v1.2h.04a3 3 0 0 1 2.8-1.5c3 0 3.5 2 3.5 4.5z"/>',
};

const isFill = name in FILL;
const inner = FILL[name] ?? STROKE[name] ?? '';
const a11y = label
  ? { role: 'img' as const, 'aria-label': label }
  : { 'aria-hidden': 'true' as const, focusable: 'false' as const };
---

<svg
  xmlns="http://www.w3.org/2000/svg"
  viewBox="0 0 24 24"
  width={size}
  height={size}
  class:list={['icon', className]}
  fill={isFill ? 'currentColor' : 'none'}
  stroke={isFill ? 'none' : 'currentColor'}
  stroke-width={isFill ? undefined : stroke}
  stroke-linecap="round"
  stroke-linejoin="round"
  {...a11y}
  set:html={inner}
/>

<style>
  .icon {
    flex: none;
    vertical-align: middle;
  }
</style>
