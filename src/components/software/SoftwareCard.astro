---
import Icon from '../ui/Icon.astro';
import Tag from '../ui/Tag.astro';
import { SOFTWARE_CATEGORIES } from '../../lib/taxonomy';
import type { Software } from '../../lib/collections';

interface Props {
  software: Software;
  headingLevel?: 2 | 3;
  featured?: boolean;
}
const { software: s, headingLevel = 3, featured = false } = Astro.props;
const Heading = `h${headingLevel}` as 'h2' | 'h3';
const cat = SOFTWARE_CATEGORIES[s.category];
const glyph =
  (s.shortName ?? s.name)
    .replace(/[^A-Za-z]/g, '')
    .slice(0, 2)
    .toUpperCase() || '·';

const links = [
  s.links.repo && { href: s.links.repo, icon: 'github', label: 'Code' },
  s.links.docs && { href: s.links.docs, icon: 'book', label: 'Docs' },
  s.links.site && { href: s.links.site, icon: 'project', label: 'Site' },
  s.links.paper && { href: s.links.paper, icon: 'pdf', label: 'Paper' },
].filter(Boolean) as { href: string; icon: string; label: string }[];
---

<article class:list={['sw', featured && 'sw--featured']}>
  <div class="sw__head">
    <span class="sw__glyph" aria-hidden="true" data-cat={s.category}>
      <span class="sw__glyph-bracket">[</span>{glyph}<span class="sw__glyph-bracket">]</span>
    </span>
    <div class="sw__headings">
      <Heading class="sw__name">
        <a href={`/software/${s.id}`} class="sw__name-link">{s.name}</a>
      </Heading>
      <p class="sw__cat mono">{cat.label}</p>
    </div>
  </div>

  <p class="sw__summary">{s.summary}</p>

  {
    s.tags.length > 0 && (
      <p class="sw__tags cluster" style="--cluster-gap: 0.3rem;">
        {s.tags.map((t) => (
          <Tag variant="tech">{t}</Tag>
        ))}
      </p>
    )
  }

  {
    links.length > 0 && (
      <div class="sw__links">
        {links.map((l) => (
          <a href={l.href} rel="noopener noreferrer" class="sw__link">
            <Icon name={l.icon} size={15} />
            <span>{l.label}</span>
          </a>
        ))}
      </div>
    )
  }
</article>

<style>
  .sw {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    height: 100%;
    padding: var(--space-m);
    border: 1px solid var(--line);
    border-radius: var(--radius-m);
    background: var(--surface);
    transition:
      border-color var(--dur-2) var(--ease),
      box-shadow var(--dur-2) var(--ease),
      transform var(--dur-2) var(--ease);
  }
  .sw:hover {
    border-color: var(--line-strong);
    box-shadow: var(--shadow-2);
    transform: translateY(-2px);
  }
  .sw--featured {
    background: var(--surface);
    border-color: var(--line-strong);
  }
  .sw__head {
    display: flex;
    align-items: center;
    gap: 0.85rem;
  }
  .sw__glyph {
    flex: 0 0 auto;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 3rem;
    height: 3rem;
    padding-inline: 0.5rem;
    font-family: var(--font-mono);
    font-weight: 500;
    font-size: 1.05rem;
    letter-spacing: 0.03em;
    color: var(--ink);
    background: var(--surface-2);
    border: 1px solid var(--line);
    border-radius: var(--radius-s);
  }
  .sw__glyph-bracket {
    color: var(--accent);
    opacity: 0.75;
    margin-inline: 0.05em;
  }
  .sw__glyph[data-cat='accelerators'] .sw__glyph-bracket,
  .sw__glyph[data-cat='ir-iteration'] .sw__glyph-bracket {
    color: var(--tech);
  }
  .sw__name {
    font-size: var(--step-1);
    line-height: 1.15;
    letter-spacing: -0.005em;
  }
  .sw__name-link {
    color: var(--ink);
    text-decoration: none;
  }
  .sw__name-link:hover {
    color: var(--accent);
  }
  .sw__cat {
    font-size: var(--step--2);
    color: var(--ink-subtle);
    margin-top: 0.15rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
  .sw__summary {
    color: var(--ink-muted);
    font-size: var(--step-0);
    line-height: 1.5;
  }
  .sw__tags {
    margin-top: auto;
  }
  .sw__links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem 0.9rem;
    padding-top: 0.75rem;
    border-top: 1px solid var(--line-hairline);
  }
  .sw__link {
    display: inline-flex;
    align-items: center;
    gap: 0.4ch;
    font-size: var(--step--1);
    font-weight: 500;
    color: var(--ink-muted);
    text-decoration: none;
  }
  .sw__link:hover {
    color: var(--accent);
  }
</style>
