---
// Inline, render-blocking theme bootstrap. Applies the saved theme before first
// paint (no flash), delegates the toggle click, and re-applies after view-transition
// swaps. Placed in <head>. No external JS, no framework.
---

<script is:inline>
  (function () {
    // Mark JS availability early so progressive-enhancement CSS can key off it.
    document.documentElement.classList.add('js');
    // Keep the mobile browser-chrome color in sync with the active theme.
    const CHROME = { light: '#faf6ee', dark: '#171310' };
    function syncChrome(t) {
      const meta = document.querySelector('meta[name="theme-color"]');
      if (meta) meta.setAttribute('content', CHROME[t] || CHROME.light);
    }
    function apply() {
      document.documentElement.classList.add('js');
      try {
        const t = localStorage.getItem('theme');
        if (t === 'light' || t === 'dark') {
          document.documentElement.setAttribute('data-theme', t);
        } else {
          document.documentElement.removeAttribute('data-theme');
        }
      } catch (e) {}
      syncChrome(effective());
    }
    function effective() {
      // Light is the default; dark only when explicitly chosen. The OS
      // prefers-color-scheme is intentionally not consulted here.
      return document.documentElement.getAttribute('data-theme') === 'dark' ? 'dark' : 'light';
    }
    function setTheme(t) {
      document.documentElement.setAttribute('data-theme', t);
      try {
        localStorage.setItem('theme', t);
      } catch (e) {}
      syncChrome(t);
      document.querySelectorAll('[data-theme-toggle]').forEach(function (b) {
        b.setAttribute(
          'aria-label',
          t === 'dark' ? 'Switch to light theme' : 'Switch to dark theme'
        );
      });
    }
    apply();
    if (!window.__themeBound) {
      window.__themeBound = true;
      document.addEventListener('click', function (e) {
        const btn = e.target && e.target.closest && e.target.closest('[data-theme-toggle]');
        if (!btn) return;
        setTheme(effective() === 'dark' ? 'light' : 'dark');
      });
      document.addEventListener('astro:after-swap', apply);
    }
  })();
</script>
