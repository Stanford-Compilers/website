---
import { SITE, absoluteUrl } from '../../config/site';

interface CitationMeta {
  name: string;
  content: string;
}

interface Props {
  title: string;
  description?: string;
  /** Canonical path (defaults to current pathname). */
  path?: string;
  /** OG image path or absolute URL. */
  image?: string;
  ogType?: 'website' | 'article' | 'profile';
  noindex?: boolean;
  /** JSON-LD structured data object(s). */
  jsonld?: Record<string, unknown> | Record<string, unknown>[];
  /** Highwire citation_* meta tags for scholarly indexing. */
  citation?: CitationMeta[];
  /** Whether this is the site root (affects OG title formatting). */
  isHome?: boolean;
}

const {
  title,
  description = SITE.description,
  path,
  image = SITE.defaultOgImage,
  ogType = 'website',
  noindex = false,
  jsonld,
  citation = [],
  isHome = false,
} = Astro.props;

const pathname = path ?? Astro.url.pathname;
const canonical = absoluteUrl(pathname);
const fullTitle = isHome ? `${SITE.name} — ${SITE.tagline}` : `${title} · ${SITE.name}`;
const ogImage = image.startsWith('http') ? image : absoluteUrl(image);
const jsonldList = jsonld ? (Array.isArray(jsonld) ? jsonld : [jsonld]) : [];
---

<title>{fullTitle}</title>
<meta name="description" content={description} />
<link rel="canonical" href={canonical} />
{noindex && <meta name="robots" content="noindex, nofollow" />}

{/* Open Graph */}
<meta property="og:type" content={ogType} />
<meta property="og:title" content={isHome ? SITE.name : title} />
<meta property="og:description" content={description} />
<meta property="og:url" content={canonical} />
<meta property="og:site_name" content={SITE.name} />
<meta property="og:locale" content="en_US" />
<meta property="og:image" content={ogImage} />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />
<meta property="og:image:alt" content={`${SITE.name} — ${SITE.tagline}`} />

{/* Twitter */}
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={isHome ? SITE.name : title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={ogImage} />

{/* Scholarly citation meta (publication pages) */}
{citation.map((c) => <meta name={c.name} content={c.content} />)}

{/* Structured data */}
{
  jsonldList.map((data) => (
    <script type="application/ld+json" is:inline set:html={JSON.stringify(data)} />
  ))
}
