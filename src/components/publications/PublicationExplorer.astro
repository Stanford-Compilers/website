---
import PublicationLedgerRow from './PublicationLedgerRow.astro';
import Icon from '../ui/Icon.astro';
import {
  groupByYear,
  yearFacets,
  venueFacets,
  topicFacets,
  memberFacets,
  awardCount,
} from '../../lib/publications';
import { venueShort, TOPICS } from '../../lib/taxonomy';
import type { Pub, Person } from '../../lib/collections';

interface Props {
  pubs: Pub[];
  people: Map<string, Person>;
}
const { pubs, people } = Astro.props;

const groups = groupByYear(pubs);
const years = yearFacets(pubs);
const venues = venueFacets(pubs);
const topics = topicFacets(pubs);
const members = memberFacets(pubs).filter((m) => people.get(m.value)); // only known people
const awards = awardCount(pubs);
const total = pubs.length;
---

<div class="explorer" data-explorer>
  <form class="toolbar" data-filters role="search" aria-label="Filter publications">
    <div class="toolbar__filters">
      <div class="search">
        <label class="search__label" for="pub-search">
          <Icon name="search" size={18} />
          <span class="visually-hidden">Search publications</span>
        </label>
        <input
          type="search"
          id="pub-search"
          name="q"
          class="search__input"
          placeholder="Search titles and authors…"
          autocomplete="off"
          data-q
        />
      </div>

      <div class="dd">
        <button
          type="button"
          class="chip"
          data-dd="year"
          aria-expanded="false"
          aria-haspopup="true"
        >
          <span>Year</span>
          <Icon name="chevron-down" size={16} class="chip__chev" />
        </button>
        <div class="dd__panel dd__panel--grid" hidden>
          {
            years.map((y) => (
              <label class="opt">
                <input type="checkbox" name="year" value={y.value} data-facet="year" />
                <span class="opt__box" aria-hidden="true" />
                <span class="opt__label mono">{y.value}</span>
                <span class="opt__count">{y.count}</span>
              </label>
            ))
          }
        </div>
      </div>

      <div class="dd">
        <button
          type="button"
          class="chip"
          data-dd="venue"
          aria-expanded="false"
          aria-haspopup="true"
        >
          <span>Venue</span>
          <Icon name="chevron-down" size={16} class="chip__chev" />
        </button>
        <div class="dd__panel" hidden>
          {
            venues.map((v) => (
              <label class="opt">
                <input type="checkbox" name="venue" value={v.value} data-facet="venue" />
                <span class="opt__box" aria-hidden="true" />
                <span class="opt__label mono">{venueShort(v.value)}</span>
                <span class="opt__count">{v.count}</span>
              </label>
            ))
          }
        </div>
      </div>

      <div class="dd">
        <button
          type="button"
          class="chip"
          data-dd="topic"
          aria-expanded="false"
          aria-haspopup="true"
        >
          <span>Topic</span>
          <Icon name="chevron-down" size={16} class="chip__chev" />
        </button>
        <div class="dd__panel" hidden>
          {
            topics.map((t) => (
              <label class="opt">
                <input type="checkbox" name="topic" value={t.value} data-facet="topic" />
                <span class="opt__box" aria-hidden="true" />
                <span class="opt__label">
                  {TOPICS[t.value as keyof typeof TOPICS]?.short ?? t.value}
                </span>
                <span class="opt__count">{t.count}</span>
              </label>
            ))
          }
        </div>
      </div>

      <div class="dd dd--member" data-member-root>
        <span class="visually-hidden" id="pub-member-label">Lab member</span>
        <button
          type="button"
          class="chip chip--member"
          data-member-button
          aria-haspopup="listbox"
          aria-expanded="false"
          aria-labelledby="pub-member-label pub-member-value"
        >
          <span
            class="chip__value"
            id="pub-member-value"
            data-member-value
            data-placeholder="Member">Member</span
          >
          <Icon name="chevron-down" size={16} class="chip__chev" />
        </button>
        <ul
          class="member__list"
          role="listbox"
          tabindex="-1"
          aria-labelledby="pub-member-label"
          data-member-list
          hidden
        >
          <li
            class="member__option"
            role="option"
            data-value=""
            data-label="Anyone"
            aria-selected="true"
          >
            <span class="member__option-check" aria-hidden="true"></span>
            <span class="member__option-name">Anyone</span>
          </li>
          {
            members.map((m) => (
              <li
                class="member__option"
                role="option"
                data-value={m.value}
                data-label={people.get(m.value)?.name}
                aria-selected="false"
              >
                <span class="member__option-check" aria-hidden="true" />
                <span class="member__option-name">{people.get(m.value)?.name}</span>
                <span class="member__option-count mono">{m.count}</span>
              </li>
            ))
          }
        </ul>
        <input type="hidden" name="member" data-member value="" />
      </div>

      <button type="button" class="chip chip--award" data-award-chip aria-pressed="false">
        <Icon name="check" size={15} />
        <span>Awards</span>
        <span class="opt__count">{awards}</span>
      </button>
    </div>

    <div class="toolbar__meta">
      <span class="toolbar__count mono" data-count role="status" aria-live="polite">
        {total} publications
      </span>
      <button type="button" class="clear" data-clear hidden>
        <Icon name="close" size={15} /> Clear all
      </button>
    </div>
  </form>

  <div class="results">
    <div class="results__list" data-list>
      {
        groups.map((group) => (
          <section class="year-group" data-year-group={group.year}>
            <h2 class="year-group__year" aria-label={`Publications from ${group.year}`}>
              <span class="mono">{group.year}</span>
              <span class="year-group__rule" aria-hidden="true" />
              <span class="year-group__count mono">{group.items.length}</span>
            </h2>
            <ul class="year-group__list ledger">
              {group.items.map((pub) => (
                <PublicationLedgerRow pub={pub} people={people} />
              ))}
            </ul>
          </section>
        ))
      }
    </div>

    <div class="results__empty" data-empty hidden>
      <p class="results__empty-title">No publications match these filters.</p>
      <p class="results__empty-text muted">
        Try removing a filter or clearing the search. The full list has {total} publications.
      </p>
      <button type="button" class="btn btn--outline btn--sm" data-clear-2>Clear all filters</button>
    </div>
  </div>
</div>

<script>
  import { setupExplorer } from './explorer';
  setupExplorer();
  document.addEventListener('astro:after-swap', setupExplorer);
</script>

<style>
  .explorer {
    display: block;
  }

  /* ---- Toolbar ------------------------------------------------ */
  /* Sticky column: the filter row never reflows; the count/clear meta
     row sits beneath it so revealing "Clear" or growing the count can't
     shift the pills sideways. */
  .toolbar {
    display: flex;
    flex-direction: column;
    position: sticky;
    top: 4.25rem;
    z-index: 40;
    padding-block: var(--space-s);
    background: var(--paper);
  }
  .toolbar__filters {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    flex-wrap: wrap;
  }

  .search {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex: 1 1 16rem;
    min-width: 12rem;
    border: 1px solid var(--line-strong);
    border-radius: var(--radius-s);
    padding: 0 0.7rem;
    background: var(--surface);
  }
  .search:focus-within {
    border-color: var(--accent);
    box-shadow: 0 0 0 3px var(--accent-tint);
  }
  .search__label {
    display: inline-flex;
    color: var(--ink-subtle);
  }
  .search__input {
    flex: 1;
    border: none;
    background: none;
    padding: 0.5rem 0;
    font-family: var(--font-sans);
    font-size: var(--step--1);
    color: var(--ink);
    min-width: 0;
  }
  .search__input:focus-visible {
    outline: none;
  }

  /* ---- Dropdown chips ----------------------------------------- */
  .dd {
    position: relative;
  }
  .chip {
    display: inline-flex;
    align-items: center;
    gap: 0.45ch;
    cursor: pointer;
    font-family: var(--font-sans);
    font-size: var(--step--1);
    font-weight: 500;
    color: var(--ink-muted);
    border: 1px solid var(--line-strong);
    border-radius: 999px;
    padding: 0.4rem 0.8rem;
    background: var(--surface);
    white-space: nowrap;
    transition:
      color var(--dur-1) var(--ease),
      border-color var(--dur-1) var(--ease),
      background var(--dur-1) var(--ease);
  }
  .chip:hover {
    color: var(--ink);
    border-color: var(--ink-subtle);
  }
  .chip:focus-visible {
    outline: none;
    border-color: var(--accent);
    box-shadow: 0 0 0 3px var(--accent-tint);
  }
  :global(:root.using-mouse) .chip:focus-visible {
    border-color: var(--line-strong);
    box-shadow: none;
  }
  .chip :global(.icon) {
    color: var(--ink-subtle);
  }
  .chip[aria-expanded='true'] {
    border-color: var(--ink-subtle);
  }
  .chip[aria-expanded='true'] :global(.chip__chev) {
    transform: rotate(180deg);
  }
  .chip__chev {
    transition: transform var(--dur-1) var(--ease);
  }
  /* Active (has a selection): accent tint + count badge. */
  .chip.is-on {
    color: var(--accent);
    border-color: var(--accent-line);
    background: var(--accent-tint);
  }
  .chip.is-on :global(.icon) {
    color: var(--accent);
  }
  .chip__n {
    display: inline-grid;
    place-items: center;
    min-width: 1.25em;
    height: 1.25em;
    padding: 0 0.35em;
    font-family: var(--font-mono);
    font-size: var(--step--2);
    color: var(--accent-contrast);
    background: var(--accent);
    border-radius: 999px;
  }
  .chip--member .chip__value {
    max-width: 12rem;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .chip--award .opt__count {
    color: inherit;
    opacity: 0.7;
  }

  .dd__panel {
    position: absolute;
    top: calc(100% + 0.4rem);
    left: 0;
    z-index: 60;
    min-width: 12rem;
    max-height: 15rem;
    overflow-y: auto;
    overscroll-behavior: contain;
    padding: 0.35rem;
    background: var(--surface);
    border: 1px solid var(--line-strong);
    border-radius: var(--radius-s);
    box-shadow: var(--shadow-2);
    scrollbar-width: thin;
    scrollbar-color: var(--line-strong) transparent;
  }
  .dd__panel[hidden] {
    display: none;
  }
  .dd__panel::-webkit-scrollbar {
    width: 6px;
  }
  .dd__panel::-webkit-scrollbar-track {
    background: transparent;
  }
  .dd__panel::-webkit-scrollbar-thumb {
    background: var(--line-strong);
    border-radius: 999px;
    border: 1px solid transparent;
    background-clip: padding-box;
  }
  .dd__panel:hover::-webkit-scrollbar-thumb {
    background: var(--ink-subtle);
    background-clip: padding-box;
  }
  .dd__panel--grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    min-width: 13rem;
  }

  .opt {
    display: flex;
    align-items: center;
    gap: 0.55ch;
    padding: 0.35rem 0.5rem;
    border-radius: var(--radius-xs);
    cursor: pointer;
    font-size: var(--step--1);
    color: var(--ink-muted);
  }
  .opt:hover {
    background: var(--surface-2);
    color: var(--ink);
  }
  .opt input {
    position: absolute;
    opacity: 0;
    width: 1px;
    height: 1px;
  }
  .opt__box {
    flex: none;
    width: 15px;
    height: 15px;
    border: 1.5px solid var(--line-strong);
    border-radius: 3px;
    display: inline-grid;
    place-items: center;
    background: var(--surface);
    transition:
      background var(--dur-1),
      border-color var(--dur-1);
  }
  .opt__box::after {
    content: '';
    width: 8px;
    height: 8px;
    border-radius: 1px;
    background: var(--accent-contrast);
    transform: scale(0);
    transition: transform var(--dur-1) var(--ease);
  }
  .opt input:checked + .opt__box {
    background: var(--accent);
    border-color: var(--accent);
  }
  .opt input:checked + .opt__box::after {
    transform: scale(1);
  }
  .opt input:focus-visible + .opt__box {
    outline: 2px solid var(--focus);
    outline-offset: 2px;
  }
  :global(:root.using-mouse) .opt input:focus-visible + .opt__box {
    outline: none;
  }
  .opt__label {
    flex: 1;
    white-space: nowrap;
  }
  .opt__count {
    font-family: var(--font-mono);
    font-size: var(--step--2);
    color: var(--ink-subtle);
  }

  .toolbar__meta {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    min-height: 1.9rem;
    margin-top: 0.7rem;
    padding-top: 0.65rem;
    border-top: 1px solid var(--line);
  }
  .clear {
    display: inline-flex;
    align-items: center;
    gap: 0.4ch;
    cursor: pointer;
    border: none;
    background: none;
    font-family: var(--font-sans);
    font-size: var(--step--1);
    font-weight: 500;
    color: var(--accent);
  }
  .clear:hover {
    text-decoration: underline;
    text-underline-offset: 0.15em;
  }
  .clear[hidden] {
    display: none;
  }
  .toolbar__count {
    font-size: var(--step--1);
    color: var(--ink-subtle);
    white-space: nowrap;
  }

  /* ---- Member listbox popup (position: fixed, JS-placed) ------ */
  .member__list {
    position: fixed;
    z-index: 60;
    max-height: 15rem;
    margin: 0;
    padding: 0.3rem;
    overflow-y: auto;
    overscroll-behavior: contain;
    list-style: none;
    background: var(--surface);
    border: 1px solid var(--line-strong);
    border-radius: var(--radius-s);
    box-shadow: var(--shadow-2);
    scrollbar-width: thin;
    scrollbar-color: var(--line-strong) transparent;
  }
  .member__list[hidden] {
    display: none;
  }
  .member__list::-webkit-scrollbar {
    width: 6px;
  }
  .member__list::-webkit-scrollbar-thumb {
    background: var(--line-strong);
    border-radius: 999px;
  }
  .member__option {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.4rem 0.5rem;
    border-radius: var(--radius-xs);
    font-size: var(--step--1);
    color: var(--ink-muted);
    cursor: pointer;
    scroll-margin: 0.3rem;
  }
  .member__option.is-active {
    background: var(--surface-2);
    color: var(--ink);
  }
  .member__option[aria-selected='true'] {
    color: var(--ink);
  }
  .member__option-check {
    flex: none;
    position: relative;
    width: 13px;
    height: 13px;
  }
  .member__option[aria-selected='true'] .member__option-check::after {
    content: '';
    position: absolute;
    left: 3px;
    top: -1px;
    width: 5px;
    height: 9px;
    border: solid var(--accent);
    border-width: 0 2px 2px 0;
    transform: rotate(45deg);
  }
  .member__option-name {
    flex: 1;
    min-width: 0;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .member__option-count {
    flex: none;
    font-size: var(--step--2);
    color: var(--ink-subtle);
  }

  /* ---- Results ------------------------------------------------ */
  .year-group {
    margin-top: var(--space-l);
  }
  .year-group__year {
    display: flex;
    align-items: center;
    gap: 1rem;
    font-family: var(--font-mono);
    font-size: var(--step-1);
    font-weight: 500;
    color: var(--ink);
    margin: 0 0 0.4rem;
  }
  .year-group__rule {
    flex: 1;
    height: 1px;
    background: var(--line);
  }
  .year-group__count {
    font-size: var(--step--2);
    color: var(--ink-subtle);
  }
  .year-group__list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .results__empty {
    padding: var(--space-2xl) var(--space-m);
    text-align: center;
    border: 1px dashed var(--line-strong);
    border-radius: var(--radius-m);
    margin-top: var(--space-l);
  }
  .results__empty[hidden] {
    display: none;
  }
  .results__empty-title {
    font-family: var(--font-display);
    font-size: var(--step-1);
    margin-bottom: var(--space-2xs);
  }
  .results__empty-text {
    max-width: 40ch;
    margin: 0 auto var(--space-m);
  }

  /* No-JS: hide the inert toolbar; the full grouped list remains. */
  :global(html:not(.js)) .toolbar {
    display: none;
  }

  @media (max-width: 46rem) {
    .toolbar {
      top: 3.75rem;
    }
    .toolbar__filters {
      gap: 0.5rem;
    }
    .dd__panel--grid {
      grid-template-columns: 1fr 1fr 1fr;
    }
  }
</style>
