---
import PublicationItem from './PublicationItem.astro';
import Icon from '../ui/Icon.astro';
import {
  groupByYear,
  yearFacets,
  venueFacets,
  topicFacets,
  memberFacets,
  awardCount,
} from '../../lib/publications';
import { venueShort, TOPICS } from '../../lib/taxonomy';
import type { Pub, Person } from '../../lib/collections';

interface Props {
  pubs: Pub[];
  people: Map<string, Person>;
}
const { pubs, people } = Astro.props;

const groups = groupByYear(pubs);
const years = yearFacets(pubs);
const venues = venueFacets(pubs);
const topics = topicFacets(pubs);
const members = memberFacets(pubs).filter((m) => people.get(m.value)); // only known people
const awards = awardCount(pubs);
const total = pubs.length;

const DIAC = /[\u0300-\u036f]/g;
// Normalized search string + filter attributes per pub (for the enhancement island).
function attrs(pub: Pub) {
  const text = `${pub.title} ${pub.authors.map((a) => a.name).join(' ')}`
    .toLowerCase()
    .normalize('NFD')
    .replace(DIAC, '');
  return {
    'data-pub-item': '',
    'data-year': String(pub.year),
    'data-venue': pub.venueKey,
    'data-topics': pub.topics.join(' '),
    'data-award': pub.award ? '1' : '0',
    'data-members': pub.authors
      .filter((a) => a.id)
      .map((a) => a.id)
      .join(' '),
    'data-text': text,
  };
}
---

<div class="explorer" data-explorer>
  <form class="filters" data-filters aria-label="Filter publications" role="search">
    <details class="filters__panel" open data-filters-panel>
      <summary class="filters__toggle">
        <Icon name="filter" size={16} />
        <span class="filters__toggle-label">Filters</span>
        <span class="filters__toggle-active mono" data-active-count hidden></span>
        <Icon name="chevron-down" size={16} class="filters__toggle-chevron" />
      </summary>
      <div class="filters__panel-body">
        <div class="filters__search">
          <label for="pub-search" class="filters__search-label">
            <Icon name="search" size={18} />
            <span class="visually-hidden">Search publications</span>
          </label>
          <input
            type="search"
            id="pub-search"
            name="q"
            class="filters__search-input"
            placeholder="Search titles and authors…"
            autocomplete="off"
            data-q
          />
        </div>

        <div class="filters__facets">
          <details class="facet" open>
            <summary class="facet__summary"
              >Year <span class="facet__n">{years.length}</span></summary
            >
            <div
              class="facet__options facet__options--grid"
              role="group"
              aria-label="Filter by year"
            >
              {
                years.map((y) => (
                  <label class="check">
                    <input type="checkbox" name="year" value={y.value} data-facet="year" />
                    <span class="check__box" aria-hidden="true" />
                    <span class="check__label mono">{y.value}</span>
                    <span class="check__count">{y.count}</span>
                  </label>
                ))
              }
            </div>
          </details>

          <details class="facet">
            <summary class="facet__summary"
              >Venue <span class="facet__n">{venues.length}</span></summary
            >
            <div class="facet__options" role="group" aria-label="Filter by venue">
              {
                venues.map((v) => (
                  <label class="check">
                    <input type="checkbox" name="venue" value={v.value} data-facet="venue" />
                    <span class="check__box" aria-hidden="true" />
                    <span class="check__label mono">{venueShort(v.value)}</span>
                    <span class="check__count">{v.count}</span>
                  </label>
                ))
              }
            </div>
          </details>

          <details class="facet">
            <summary class="facet__summary"
              >Topic <span class="facet__n">{topics.length}</span></summary
            >
            <div class="facet__options" role="group" aria-label="Filter by research topic">
              {
                topics.map((t) => (
                  <label class="check">
                    <input type="checkbox" name="topic" value={t.value} data-facet="topic" />
                    <span class="check__box" aria-hidden="true" />
                    <span class="check__label">
                      {TOPICS[t.value as keyof typeof TOPICS]?.short ?? t.value}
                    </span>
                    <span class="check__count">{t.count}</span>
                  </label>
                ))
              }
            </div>
          </details>

          <div class="facet facet--flat">
            <label class="check check--inline">
              <input type="checkbox" name="award" value="1" data-award />
              <span class="check__box" aria-hidden="true"></span>
              <span class="check__label"
                >Award winners <span class="check__count">{awards}</span></span
              >
            </label>
          </div>

          <div class="facet facet--flat">
            <span class="member__label" id="pub-member-label">Lab member</span>
            <div class="member" data-member-root>
              <button
                type="button"
                class="member__button member__button--placeholder"
                data-member-button
                aria-haspopup="listbox"
                aria-expanded="false"
                aria-labelledby="pub-member-label pub-member-value"
              >
                <span class="member__value" id="pub-member-value" data-member-value>Anyone</span>
                <Icon name="chevron-down" size={16} class="member__chevron" />
              </button>
              <ul
                class="member__list"
                role="listbox"
                tabindex="-1"
                aria-labelledby="pub-member-label"
                data-member-list
                hidden
              >
                <li
                  class="member__option"
                  role="option"
                  data-value=""
                  data-label="Anyone"
                  aria-selected="true"
                >
                  <span class="member__option-check" aria-hidden="true"></span>
                  <span class="member__option-name">Anyone</span>
                </li>
                {
                  members.map((m) => (
                    <li
                      class="member__option"
                      role="option"
                      data-value={m.value}
                      data-label={people.get(m.value)?.name}
                      aria-selected="false"
                    >
                      <span class="member__option-check" aria-hidden="true" />
                      <span class="member__option-name">{people.get(m.value)?.name}</span>
                      <span class="member__option-count mono">{m.count}</span>
                    </li>
                  ))
                }
              </ul>
              <input type="hidden" name="member" data-member value="" />
            </div>
          </div>
        </div>

        <button type="button" class="filters__clear" data-clear hidden>
          <Icon name="close" size={15} /> Clear all filters
        </button>
      </div>
    </details>
  </form>

  <script is:inline>
    // Collapse the filter panel by default on small screens, before first paint,
    // so the listing isn't pushed far down. Desktop keeps it open (summary hidden).
    (function () {
      const p = document.querySelector('[data-filters-panel]');
      if (p) p.open = !window.matchMedia('(max-width: 60rem)').matches;
    })();
  </script>

  <div class="results">
    <p class="results__count" data-count role="status" aria-live="polite">
      {total} publications
    </p>

    <div class="results__list" data-list>
      {
        groups.map((group) => (
          <section class="year-group" data-year-group={group.year}>
            <h2 class="year-group__year" aria-label={`Publications from ${group.year}`}>
              <span class="mono">{group.year}</span>
              <span class="year-group__rule" aria-hidden="true" />
              <span class="year-group__count mono">{group.items.length}</span>
            </h2>
            <ul class="year-group__list">
              {group.items.map((pub) => (
                <li {...attrs(pub)}>
                  <PublicationItem pub={pub} people={people} headingLevel={3} />
                </li>
              ))}
            </ul>
          </section>
        ))
      }
    </div>

    <div class="results__empty" data-empty hidden>
      <p class="results__empty-title">No publications match these filters.</p>
      <p class="results__empty-text muted">
        Try removing a filter or clearing the search. The full list has {total} publications.
      </p>
      <button type="button" class="btn btn--outline btn--sm" data-clear-2>Clear all filters</button>
    </div>
  </div>
</div>

<script>
  import { setupExplorer } from './explorer';
  setupExplorer();
  document.addEventListener('astro:after-swap', setupExplorer);
</script>

<style>
  .explorer {
    display: grid;
    grid-template-columns: 17rem 1fr;
    gap: var(--space-xl);
    align-items: start;
  }

  /* Filters ------------------------------------------------ */
  .filters {
    position: sticky;
    top: 5.5rem;
    /* Pin the rail to the viewport and let it scroll as one unit, so every
       control stays reachable no matter how many facets are expanded. The
       6px inset gives focus rings and the scrollbar room without clipping;
       the matching negative margin keeps content flush with the column. */
    max-height: calc(100dvh - 7rem);
    overflow-y: auto;
    overscroll-behavior: contain;
    padding: 6px;
    margin: -6px;
    scrollbar-width: thin;
    scrollbar-color: var(--line-strong) transparent;
  }
  .filters::-webkit-scrollbar {
    width: 6px;
  }
  .filters::-webkit-scrollbar-track {
    background: transparent;
  }
  .filters::-webkit-scrollbar-thumb {
    background: var(--line-strong);
    border-radius: 999px;
    border: 1px solid transparent;
    background-clip: padding-box;
  }
  .filters:hover::-webkit-scrollbar-thumb {
    background: var(--ink-subtle);
    background-clip: padding-box;
  }
  .filters__panel-body {
    display: flex;
    flex-direction: column;
    gap: var(--space-s);
  }
  /* Collapse toggle is desktop-hidden; the panel is always open there. */
  .filters__toggle {
    display: none;
  }
  .filters__search {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    border: 1px solid var(--line-strong);
    border-radius: var(--radius-s);
    padding: 0 0.7rem;
    background: var(--surface);
  }
  .filters__search:focus-within {
    border-color: var(--accent);
    box-shadow: 0 0 0 3px var(--accent-tint);
  }
  .filters__search-label {
    display: inline-flex;
    color: var(--ink-subtle);
  }
  .filters__search-input {
    flex: 1;
    border: none;
    background: none;
    padding: 0.6rem 0;
    font-size: var(--step--1);
    color: var(--ink);
    min-width: 0;
  }
  .filters__search-input:focus-visible {
    outline: none;
  }
  .filters__facets {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }
  .facet {
    border-bottom: 1px solid var(--line-hairline);
  }
  .facet--flat {
    padding-block: 0.75rem;
  }
  .facet__summary {
    display: flex;
    align-items: center;
    gap: 0.5ch;
    padding: 0.7rem 0;
    font-family: var(--font-sans);
    font-size: var(--step--1);
    font-weight: 600;
    color: var(--ink);
    cursor: pointer;
    list-style: none;
  }
  .facet__summary::-webkit-details-marker {
    display: none;
  }
  .facet__summary::after {
    content: '';
    margin-left: auto;
    width: 8px;
    height: 8px;
    border-right: 1.5px solid var(--ink-subtle);
    border-bottom: 1.5px solid var(--ink-subtle);
    transform: rotate(45deg);
    transition: transform var(--dur-1) var(--ease);
  }
  .facet[open] .facet__summary::after {
    transform: rotate(-135deg);
  }
  .facet__n {
    font-family: var(--font-mono);
    font-size: var(--step--2);
    color: var(--ink-subtle);
    font-weight: 400;
  }
  .facet__options {
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
    padding-bottom: 0.75rem;
  }
  .facet__options--grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0.1rem 0.5rem;
  }

  .check {
    display: flex;
    align-items: center;
    gap: 0.55ch;
    padding: 0.28rem 0.3rem;
    border-radius: var(--radius-xs);
    cursor: pointer;
    font-size: var(--step--1);
    color: var(--ink-muted);
  }
  .check:hover {
    background: var(--surface-2);
    color: var(--ink);
  }
  .check input {
    position: absolute;
    opacity: 0;
    width: 1px;
    height: 1px;
  }
  .check__box {
    flex: none;
    width: 15px;
    height: 15px;
    border: 1.5px solid var(--line-strong);
    border-radius: 3px;
    display: inline-grid;
    place-items: center;
    background: var(--surface);
    transition:
      background var(--dur-1),
      border-color var(--dur-1);
  }
  .check__box::after {
    content: '';
    width: 8px;
    height: 8px;
    border-radius: 1px;
    background: var(--accent-contrast);
    transform: scale(0);
    transition: transform var(--dur-1) var(--ease);
  }
  .check input:checked + .check__box {
    background: var(--accent);
    border-color: var(--accent);
  }
  .check input:checked + .check__box::after {
    transform: scale(1);
  }
  .check input:focus-visible + .check__box {
    outline: 2px solid var(--focus);
    outline-offset: 2px;
  }
  :global(:root.using-mouse) .check input:focus-visible + .check__box {
    outline: none;
  }
  .check__label {
    flex: 1;
  }
  .check__count {
    font-family: var(--font-mono);
    font-size: var(--step--2);
    color: var(--ink-subtle);
  }
  .check--inline {
    padding: 0;
  }

  .member__label {
    display: block;
    font-size: var(--step--1);
    font-weight: 600;
    margin-bottom: 0.4rem;
  }
  .member {
    position: relative;
  }
  /* Trigger — mirrors the search field's box so the rail reads as one system. */
  .member__button {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    width: 100%;
    padding: 0.5rem 0.7rem;
    border: 1px solid var(--line-strong);
    border-radius: var(--radius-s);
    background: var(--surface);
    font-family: var(--font-sans);
    font-size: var(--step--1);
    color: var(--ink);
    text-align: left;
    cursor: pointer;
  }
  .member__button:hover {
    border-color: var(--ink-subtle);
  }
  .member__button:focus-visible {
    outline: none;
    border-color: var(--accent);
    box-shadow: 0 0 0 3px var(--accent-tint);
  }
  :global(:root.using-mouse) .member__button:focus-visible {
    border-color: var(--line-strong);
    box-shadow: none;
  }
  .member__value {
    flex: 1;
    min-width: 0;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .member__button--placeholder .member__value {
    color: var(--ink-muted);
  }
  .member__chevron {
    flex: none;
    color: var(--ink-subtle);
    transition: transform var(--dur-1) var(--ease);
  }
  .member__button[aria-expanded='true'] .member__chevron {
    transform: rotate(180deg);
  }

  /* Popup listbox. Fixed (not absolute) so it escapes the filter rail's
     `overflow-y: auto` clipping — the rail scrolls, and an absolute popup on
     the last facet would be cut off at the rail's bottom edge. JS sets
     left/width/top-or-bottom from the trigger's rect and flips it upward when
     there isn't room below. */
  .member__list {
    position: fixed;
    z-index: 30;
    max-height: 15rem;
    margin: 0;
    padding: 0.3rem;
    overflow-y: auto;
    overscroll-behavior: contain;
    list-style: none;
    background: var(--surface);
    border: 1px solid var(--line-strong);
    border-radius: var(--radius-s);
    box-shadow: var(--shadow-2);
    scrollbar-width: thin;
    scrollbar-color: var(--line-strong) transparent;
  }
  .member__list[hidden] {
    display: none;
  }
  .member__list::-webkit-scrollbar {
    width: 6px;
  }
  .member__list::-webkit-scrollbar-thumb {
    background: var(--line-strong);
    border-radius: 999px;
  }
  .member__option {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.4rem 0.5rem;
    border-radius: var(--radius-xs);
    font-size: var(--step--1);
    color: var(--ink-muted);
    cursor: pointer;
    scroll-margin: 0.3rem;
  }
  /* Keyboard/pointer focus highlight — one option "active" at a time. */
  .member__option.is-active {
    background: var(--surface-2);
    color: var(--ink);
  }
  .member__option[aria-selected='true'] {
    color: var(--ink);
  }
  .member__option-check {
    flex: none;
    position: relative;
    width: 13px;
    height: 13px;
  }
  .member__option[aria-selected='true'] .member__option-check::after {
    content: '';
    position: absolute;
    left: 3px;
    top: -1px;
    width: 5px;
    height: 9px;
    border: solid var(--accent);
    border-width: 0 2px 2px 0;
    transform: rotate(45deg);
  }
  .member__option-name {
    flex: 1;
    min-width: 0;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .member__option-count {
    flex: none;
    font-size: var(--step--2);
    color: var(--ink-subtle);
  }

  .filters__clear {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.5ch;
    margin-top: 0.25rem;
    padding: 0.55rem 0.8rem;
    font-size: var(--step--1);
    font-weight: 600;
    color: var(--accent);
    border: 1px solid var(--accent-line);
    border-radius: var(--radius-s);
    background: var(--accent-tint);
  }
  .filters__clear:hover {
    border-color: var(--accent);
  }

  /* Results ------------------------------------------------ */
  /* A quiet caption above the list; the first year's rule is the divider, so
     this needs no border of its own (that would stack a second line under it). */
  .results__count {
    font-family: var(--font-mono);
    font-size: var(--step--1);
    color: var(--ink-subtle);
    margin-bottom: var(--space-s);
  }
  /* Every year heading — including the first — sits a full step below the
     caption above it. This keeps the default listing's "52 publications → 2026"
     gap identical to the filtered "Showing … → 2025" gap, where the first
     visible group is never the DOM :first-child. */
  .year-group {
    margin-top: var(--space-l);
  }
  .year-group__year {
    display: flex;
    align-items: center;
    gap: 1rem;
    font-family: var(--font-mono);
    font-size: var(--step-1);
    font-weight: 500;
    color: var(--ink);
    letter-spacing: 0;
  }
  .year-group__rule {
    flex: 1;
    height: 1px;
    background: var(--line);
  }
  .year-group__count {
    font-size: var(--step--2);
    color: var(--ink-subtle);
  }
  .year-group__list {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .year-group__list > li[hidden] {
    display: none;
  }
  /* The year heading's rule already divides each group, so the first shown
     item shouldn't draw its own full-width hairline right beneath it (two
     stacked lines). Strip every item's top border, then re-add it only to a
     shown item that follows another shown item — i.e. every one except the
     first visible. `visible ~ visible` keeps this correct under any filter. */
  .year-group__list > li > :global(.pub) {
    border-top: none;
  }
  .year-group__list > li:not([hidden]) ~ li:not([hidden]) > :global(.pub) {
    border-top: 1px solid var(--line-hairline);
  }

  .results__empty {
    padding: var(--space-2xl) var(--space-m);
    text-align: center;
    border: 1px dashed var(--line-strong);
    border-radius: var(--radius-m);
    margin-top: var(--space-l);
  }
  .results__empty-title {
    font-family: var(--font-display);
    font-size: var(--step-1);
    margin-bottom: var(--space-2xs);
  }
  .results__empty-text {
    max-width: 40ch;
    margin: 0 auto var(--space-m);
  }

  /* Enhancement-only: hide clear button until JS shows it. */
  .filters__clear[hidden],
  .results__empty[hidden] {
    display: none;
  }

  /* No-JS: hide the (inert) filters; the complete grouped list remains. */
  :global(html:not(.js)) .filters {
    display: none;
  }
  :global(html:not(.js)) .explorer {
    grid-template-columns: 1fr;
  }

  @media (max-width: 60rem) {
    .explorer {
      grid-template-columns: 1fr;
      gap: var(--space-l);
    }
    .filters {
      position: static;
      max-height: none;
      overflow: visible;
      padding: 0;
      margin: 0;
    }
    .facet__options--grid {
      grid-template-columns: repeat(4, 1fr);
    }

    /* Filters collapse behind a tap target so the listing stays reachable. */
    .filters__toggle {
      display: flex;
      align-items: center;
      gap: 0.6ch;
      width: 100%;
      padding: 0.7rem 0.9rem;
      font-family: var(--font-sans);
      font-size: var(--step--1);
      font-weight: 600;
      color: var(--ink);
      background: var(--surface);
      border: 1px solid var(--line-strong);
      border-radius: var(--radius-s);
      cursor: pointer;
      list-style: none;
    }
    .filters__toggle::-webkit-details-marker {
      display: none;
    }
    .filters__toggle-active {
      display: inline-grid;
      place-items: center;
      min-width: 1.3rem;
      height: 1.3rem;
      padding: 0 0.4rem;
      font-size: var(--step--2);
      color: var(--accent-contrast);
      background: var(--accent);
      border-radius: 999px;
    }
    .filters__toggle-active[hidden] {
      display: none;
    }
    .filters__toggle-chevron {
      margin-left: auto;
      color: var(--ink-subtle);
      transition: transform var(--dur-1) var(--ease);
    }
    .filters__panel[open] .filters__toggle-chevron {
      transform: rotate(180deg);
    }
    .filters__panel[open] .filters__panel-body {
      padding-top: var(--space-s);
    }
  }
</style>
