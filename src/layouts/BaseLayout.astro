---
import '../styles/global.css';
import { SITE } from '../config/site';
import SEO from '../components/global/SEO.astro';
import ThemeScript from '../components/global/ThemeScript.astro';
import Header from '../components/navigation/Header.astro';
import Footer from '../components/global/Footer.astro';
import ClipboardScript from '../components/global/ClipboardScript.astro';
import { ClientRouter } from 'astro:transitions';

interface Props {
  title: string;
  description?: string;
  path?: string;
  image?: string;
  ogType?: 'website' | 'article' | 'profile';
  noindex?: boolean;
  jsonld?: Record<string, unknown> | Record<string, unknown>[];
  citation?: { name: string; content: string }[];
  isHome?: boolean;
  mainClass?: string;
}

const {
  title,
  description,
  path,
  image,
  ogType,
  noindex,
  jsonld,
  citation,
  isHome = false,
  mainClass,
} = Astro.props;

// Site-wide organization structured data (present on every page).
const orgJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'ResearchOrganization',
  name: SITE.name,
  alternateName: SITE.pi.name + ' Research Group',
  description: SITE.description,
  url: SITE.url,
  parentOrganization: {
    '@type': 'CollegeOrUniversity',
    name: SITE.institution.name,
    url: SITE.institution.url,
  },
  member: {
    '@type': 'Person',
    name: SITE.pi.name,
    jobTitle: SITE.pi.title,
    email: `mailto:${SITE.pi.email}`,
  },
};

const pageJsonLd = jsonld ? (Array.isArray(jsonld) ? jsonld : [jsonld]) : [];
const allJsonLd = [orgJsonLd, ...pageJsonLd];
---

<!doctype html>
<html lang={SITE.locale}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <ThemeScript />

    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="icon" href="/favicon.ico" sizes="32x32" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <!-- Light chrome by default; ThemeScript swaps this to the dark value when the
         user explicitly chooses dark, so it stays in sync with the actual theme. -->
    <meta name="theme-color" content="#faf6ee" />
    <meta name="generator" content={Astro.generator} />

    {
      /* Preload the critical fonts; the rest use font-display: swap. Fraunces is
        the hero headline (the LCP text), so it is preloaded alongside body Plex. */
    }
    <link rel="preload" href="/fonts/plex-sans-400.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/plex-sans-500.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/fraunces-var.woff2" as="font" type="font/woff2" crossorigin />

    <SEO
      title={title}
      description={description}
      path={path}
      image={image}
      ogType={ogType}
      noindex={noindex}
      jsonld={allJsonLd}
      citation={citation}
      isHome={isHome}
    />

    {SITE.features.viewTransitions && <ClientRouter />}
  </head>
  <body>
    <a href="#main" class="skip-link">Skip to content</a>
    <Header />
    <main id="main" class:list={['site-main', mainClass]} tabindex="-1">
      <slot />
    </main>
    <Footer />
    <ClipboardScript />

    <script is:inline>
      // Focus modality: only show the keyboard focus ring during genuine
      // keyboard navigation. Marks .using-mouse on pointer input so CSS can
      // suppress the ring the browser's :focus-visible heuristic otherwise
      // resurrects when a modifier key (Shift, etc.) is pressed after a click.
      // Bound once, survives view transitions; no-op degrades to native focus.
      (function () {
        if (window.__focusModalityBound) return;
        window.__focusModalityBound = true;
        const root = document.documentElement;
        // Modifier keys alone are not navigation — they must not restore the ring.
        const MODIFIERS = {
          Shift: 1,
          Control: 1,
          Alt: 1,
          Meta: 1,
          CapsLock: 1,
          NumLock: 1,
          ScrollLock: 1,
          Hyper: 1,
          Super: 1,
          Fn: 1,
          FnLock: 1,
        };
        function pointer() {
          root.classList.add('using-mouse');
        }
        function keyboard(e) {
          if (!MODIFIERS[e.key]) root.classList.remove('using-mouse');
        }
        window.addEventListener('pointerdown', pointer, true);
        window.addEventListener('mousedown', pointer, true);
        window.addEventListener('touchstart', pointer, true);
        window.addEventListener('keydown', keyboard, true);
      })();
    </script>

    <style>
      .site-main {
        display: block;
        outline: none;
      }
    </style>
  </body>
</html>
