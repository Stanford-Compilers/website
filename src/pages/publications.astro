---
import PageLayout from '../layouts/PageLayout.astro';
import PublicationExplorer from '../components/publications/PublicationExplorer.astro';
import { loadPublications, peopleMap } from '../lib/collections';

const pubs = await loadPublications();
const people = await peopleMap();
const firstYear = Math.min(...pubs.map((p) => p.year));
const lastYear = Math.max(...pubs.map((p) => p.year));

const jsonld = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: 'Publications',
  description: `Publications from the Stanford Compilers Lab, ${firstYear}–${lastYear}.`,
  isPartOf: { '@type': 'WebSite', name: 'Stanford Compilers Lab' },
};
---

<PageLayout
  title="Publications"
  kicker="Publications"
  image="/og/publications.png"
  lead="Papers on languages, compilers, and systems for computation across data representations and machines."
  description={`All ${pubs.length} publications from the Stanford Compilers Lab (${firstYear}–${lastYear}), with search and filtering by year, venue, topic, award, and lab member.`}
  jsonld={jsonld}
>
  <section class="section--tight">
    <div class="container container--wide">
      <PublicationExplorer pubs={pubs} people={people} />
    </div>
  </section>
</PageLayout>
