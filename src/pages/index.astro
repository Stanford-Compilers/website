---
import BaseLayout from '../layouts/BaseLayout.astro';
import HeroPipeline from '../components/home/HeroPipeline.astro';
import TransformStack from '../components/research/TransformStack.astro';
import SectionHead from '../components/ui/SectionHead.astro';
import PublicationItem from '../components/publications/PublicationItem.astro';
import SoftwareCard from '../components/software/SoftwareCard.astro';
import Button from '../components/ui/Button.astro';
import Icon from '../components/ui/Icon.astro';
import { SITE } from '../config/site';
import { loadFeaturedPublications, loadFeaturedSoftware, peopleMap } from '../lib/collections';

const featuredPubs = (await loadFeaturedPublications()).slice(0, 5);
const featuredSoftware = await loadFeaturedSoftware(6);
const pMap = await peopleMap();

const themes = [
  {
    n: '01',
    icon: 'layers',
    title: 'Portability across data representations',
    body: 'Programs should move between dense, sparse, graph, and custom layouts without being rewritten around each representation.',
    href: '/research#representation',
  },
  {
    n: '02',
    icon: 'compass',
    title: 'One program, many machines',
    body: 'Mapping the same high-level intent onto CPUs, GPUs, accelerators, distributed clusters, and heterogeneous systems.',
    href: '/research#machines',
  },
  {
    n: '03',
    icon: 'chip',
    title: 'Compilers that generate compilers',
    body: 'Meta-compilers, VM generators. Instead of building one compiler at a time, we build methods and generators for creating whole compiler families.',
    href: '/research#meta',
  },
  {
    n: '04',
    icon: 'code',
    title: 'Sparse & structured computation',
    body: 'Compiling tensor, array, and relational computation over sparse and irregular data without sacrificing performance.',
    href: '/publications?topic=sparse-tensor-algebra',
  },
];

// Highlight a key phrase of the tagline in cardinal italic. Falls back to the
// plain tagline if the phrase ever changes in the config.
const HERO_HIGHLIGHT = 'data representations';
const hlIndex = SITE.tagline.indexOf(HERO_HIGHLIGHT);
const heroBefore = hlIndex >= 0 ? SITE.tagline.slice(0, hlIndex) : SITE.tagline;
const heroAfter = hlIndex >= 0 ? SITE.tagline.slice(hlIndex + HERO_HIGHLIGHT.length) : '';
---

<BaseLayout title="Home" isHome path="/">
  {/* ---------------- Hero ---------------- */}
  <section class="hero" aria-labelledby="hero-title">
    <div class="container container--wide">
      <div class="hero__masthead">
        <p class="kicker hero__kicker">Programming Languages × Systems</p>
        <p class="hero__folio" aria-hidden="true">Stanford Computer Science · 37.428° N</p>
        <h1 class="hero__title" id="hero-title">
          {heroBefore}<em>{HERO_HIGHLIGHT}</em>{heroAfter}
        </h1>
      </div>

      <div class="hero__lower">
        <div class="hero__deck">
          <p class="hero__lead">
            We build programming languages and compilers that make sophisticated software fast and
            portable across changing data representations and hardware.
          </p>
          <div class="hero__cta">
            <Button href="/research" variant="primary" iconRight="arrow-right"
              >Read the research</Button
            >
            <Button href="/publications" variant="outline">Browse publications</Button>
          </div>
        </div>

        <figure class="hero__figure">
          <figcaption class="hero__figcaption">
            <span>Fig. 01 — Sparse Tensor Algebra</span>
            <span aria-hidden="true">Abstraction → Execution</span>
          </figcaption>
          <HeroPipeline />
        </figure>
      </div>
    </div>
  </section>

  {/* ---------------- Research themes ---------------- */}
  <section class="section" aria-labelledby="themes-title">
    <div class="container container--wide">
      <SectionHead
        kicker="Research"
        title="Four threads, one question"
        description="How can a single high-level program stay fast as its data and target keep changing? Our work approaches that question from several directions."
        id="themes-title"
        href="/research"
        linkLabel="The full picture"
      />
      <ul class="themes">
        {
          themes.map((t) => (
            <li class="theme">
              <a href={t.href} class="theme__link">
                <span class="theme__top">
                  <span class="theme__n mono">{t.n}</span>
                  <span class="theme__icon">
                    <Icon name={t.icon} size={20} />
                  </span>
                </span>
                <h3 class="theme__title">{t.title}</h3>
                <p class="theme__body">{t.body}</p>
                <span class="theme__more mono">
                  Explore <Icon name="arrow-right" size={14} />
                </span>
              </a>
            </li>
          ))
        }
      </ul>
    </div>
  </section>

  {/* ---------------- From abstractions to machines ---------------- */}
  <section class="section band" aria-labelledby="stack-title">
    <div class="container container--wide stack-band">
      <div class="stack-band__intro">
        <p class="kicker">From abstractions to machines</p>
        <h2 id="stack-title" class="stack-band__title">
          The same computation, lowered layer by layer
        </h2>
        <p class="stack-band__text muted">
          A program starts as a high-level description. At each layer, the compiler fixes one more
          decision — the representation, then the schedule, then the target — until it becomes code
          for a specific machine. Because these choices are made separately, changing the data
          format or the hardware does not mean rewriting the program.
        </p>
        <p class="stack-band__text muted">
          This separation is what makes a single library or language <em>polymorphic</em> over data structures
          and portable across machines.
        </p>
      </div>
      <div class="stack-band__diagram">
        <TransformStack />
      </div>
    </div>
  </section>

  {/* ---------------- Featured software ---------------- */}
  <section class="section" aria-labelledby="software-title">
    <div class="container container--wide">
      <SectionHead
        kicker="Software"
        title="Systems we build"
        description="Our research ships as compilers, languages, and libraries — a connected body of work rather than isolated tools."
        id="software-title"
        href="/software"
        linkLabel="All software"
      />
      <ul class="sw-grid">
        {
          featuredSoftware.map((s) => (
            <li>
              <SoftwareCard software={s} featured />
            </li>
          ))
        }
      </ul>
    </div>
  </section>

  {/* ---------------- Selected publications ---------------- */}
  <section class="section band" aria-labelledby="pubs-title">
    <div class="container container--wide">
      <SectionHead
        kicker="Publications"
        title="Selected & recent work"
        description="A few papers that show the range of the group. Every paper, with search and filters, is on the publications page."
        id="pubs-title"
        href="/publications"
        linkLabel="All publications"
      />
      <div class="pub-list">
        {featuredPubs.map((pub) => <PublicationItem pub={pub} people={pMap} headingLevel={3} />)}
      </div>
    </div>
  </section>

  {/* ---------------- Join CTA ---------------- */}
  {
    SITE.features.homeJoinCta && (
      <section class="section" aria-labelledby="join-title">
        <div class="container container--wide">
          <div class="join-cta">
            <div class="join-cta__marks" aria-hidden="true">
              <>
                <span>[</span>
                <span>·</span>
                <span>·</span>
                <span>]</span>
              </>
            </div>
            <h2 class="join-cta__title" id="join-title">
              Interested in this kind of work?
            </h2>
            <p class="join-cta__text">
              We welcome prospective PhD students, current Stanford students, and collaborators who
              are curious about languages, compilers, and the systems that run underneath.
            </p>
            <div class="join-cta__actions">
              <Button href="/join" variant="primary" iconRight="arrow-right">
                How to get involved
              </Button>
            </div>
          </div>
        </div>
      </section>
    )
  }
</BaseLayout>

<style>
  /* ---------------- Hero ---------------- */
  .hero {
    padding-top: clamp(2rem, 1rem + 4vw, 4.25rem);
    padding-bottom: clamp(2.75rem, 1.5rem + 4.5vw, 5.5rem);
  }

  /* Masthead: a ruled kicker (top-left) and a vertical folio (right edge) frame
     a wide serif headline — the composition that gives the hero its balance. */
  .hero__masthead {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    column-gap: clamp(1rem, 0.4rem + 2vw, 2.5rem);
  }
  .hero__kicker {
    grid-column: 1;
    grid-row: 1;
    align-self: start;
    justify-self: start;
    margin: 0;
    padding-top: 0.9rem;
    border-top: 1px solid var(--ink);
  }
  .hero__title {
    grid-column: 1;
    grid-row: 2;
    margin: clamp(1.4rem, 0.6rem + 3vw, 2.75rem) 0 0;
    max-width: 20ch;
    font-size: clamp(2.9rem, 1.25rem + 6.7vw, 6rem);
    font-weight: 420;
    line-height: 0.94;
    letter-spacing: -0.025em;
    text-wrap: balance;
  }
  .hero__title em {
    font-style: italic;
    font-weight: 400;
    color: var(--accent);
  }
  .hero__folio {
    grid-column: 2;
    grid-row: 1 / span 2;
    justify-self: end;
    align-self: stretch;
    margin: 0;
    padding-left: 0.85rem;
    border-left: 1px solid var(--line);
    writing-mode: vertical-rl;
    transform: rotate(180deg);
    color: var(--ink-subtle);
    font-family: var(--font-mono);
    font-size: var(--step--2);
    letter-spacing: 0.16em;
    text-transform: uppercase;
    white-space: nowrap;
  }

  /* Lower zone: supporting copy + CTAs on the left, the pipeline figure on the
     right, both hung from a shared hairline rule. */
  .hero__lower {
    display: grid;
    grid-template-columns: minmax(0, 4fr) minmax(0, 7fr);
    column-gap: clamp(1.5rem, 0.6rem + 3vw, 4rem);
    row-gap: var(--space-xl);
    align-items: start;
    margin-top: clamp(2.5rem, 1.4rem + 4vw, 4.75rem);
  }
  .hero__deck {
    grid-column: 1;
    padding-top: 1.1rem;
    border-top: 1px solid var(--line-strong);
  }
  /* Tagline styled after the editorial-atlas hero deck: a large, light Fraunces
     serif line in full ink with tight leading — not muted body sans. */
  .hero__lead {
    margin: 0;
    max-width: 32ch;
    font-family: var(--font-display);
    font-size: clamp(1.25rem, 1.05rem + 0.85vw, 1.625rem);
    font-weight: 390;
    line-height: 1.24;
    color: var(--ink);
  }
  .hero__cta {
    margin-top: var(--space-l);
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-s);
  }
  .hero__figure {
    grid-column: 2;
    margin: 0;
  }
  .hero__figcaption {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: var(--space-s);
    padding-top: 1.1rem;
    border-top: 1px solid var(--line-strong);
    font-family: var(--font-mono);
    font-size: var(--step--2);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--ink-subtle);
  }

  @media (max-width: 62rem) {
    .hero__lower {
      grid-template-columns: 1fr;
      row-gap: var(--space-l);
    }
    .hero__deck,
    .hero__figure {
      grid-column: 1;
    }
  }
  @media (max-width: 48rem) {
    .hero__masthead {
      grid-template-columns: 1fr;
    }
    .hero__folio {
      display: none;
    }
    .hero__title {
      grid-column: 1;
      max-width: 16ch;
    }
  }

  /* ---------------- Themes ---------------- */
  .themes {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--space-s);
  }
  .theme {
    display: flex;
  }
  .theme__link {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    padding: var(--space-m);
    border: 1px solid var(--line);
    border-radius: var(--radius-m);
    background: var(--surface);
    text-decoration: none;
    color: inherit;
    width: 100%;
    transition:
      border-color var(--dur-2) var(--ease),
      background var(--dur-2) var(--ease),
      transform var(--dur-2) var(--ease);
  }
  .theme__link:hover {
    border-color: var(--line-strong);
    transform: translateY(-2px);
  }
  .theme__top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    color: var(--accent);
  }
  .theme__n {
    font-size: var(--step--1);
    font-weight: 500;
  }
  .theme__icon {
    color: var(--tech);
  }
  .theme__title {
    font-size: var(--step-1);
    line-height: 1.15;
    letter-spacing: -0.005em;
  }
  .theme__body {
    color: var(--ink-muted);
    font-size: var(--step--1);
    line-height: 1.5;
    flex: 1;
  }
  .theme__more {
    display: inline-flex;
    align-items: center;
    gap: 0.4ch;
    font-size: var(--step--2);
    color: var(--ink-subtle);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
  .theme__link:hover .theme__more {
    color: var(--accent);
  }

  /* ---------------- Band sections ---------------- */
  .band {
    background: var(--paper-2);
    border-block: 1px solid var(--line-hairline);
  }
  .stack-band {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-2xl);
    align-items: start;
  }
  .stack-band__title {
    font-size: var(--step-3);
    margin-top: var(--space-s);
    max-width: 16ch;
  }
  .stack-band__text {
    margin-top: var(--space-m);
    max-width: 52ch;
  }
  .stack-band__text em {
    font-style: italic;
    color: var(--ink);
  }
  .stack-band__diagram {
    padding-top: var(--space-2xs);
  }

  /* ---------------- Software grid ---------------- */
  .sw-grid {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-s);
  }

  /* ---------------- Publications ---------------- */
  .pub-list {
    border-bottom: 1px solid var(--line-hairline);
  }

  /* ---------------- Join CTA ---------------- */
  .join-cta {
    text-align: center;
    padding: clamp(2rem, 1.4rem + 3vw, 3.5rem);
    border: 1px solid var(--line-strong);
    border-radius: var(--radius-l);
    background:
      radial-gradient(120% 120% at 50% 0%, var(--accent-tint), transparent 60%), var(--surface);
  }
  .join-cta__marks {
    display: flex;
    justify-content: center;
    gap: 0.5rem;
    font-family: var(--font-mono);
    font-size: 1.5rem;
    color: var(--accent);
    margin-bottom: var(--space-s);
  }
  .join-cta__title {
    font-size: var(--step-3);
  }
  .join-cta__text {
    margin: var(--space-s) auto 0;
    max-width: 52ch;
    color: var(--ink-muted);
  }
  .join-cta__actions {
    margin-top: var(--space-l);
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-s);
    justify-content: center;
  }

  /* ---------------- Responsive ---------------- */
  @media (max-width: 62rem) {
    .themes {
      grid-template-columns: repeat(2, 1fr);
    }
    .sw-grid {
      grid-template-columns: repeat(2, 1fr);
    }
    .stack-band {
      grid-template-columns: 1fr;
      gap: var(--space-xl);
    }
  }
  @media (max-width: 40rem) {
    .themes {
      grid-template-columns: 1fr;
    }
    .sw-grid {
      grid-template-columns: 1fr;
    }
    .people-preview__list {
      grid-template-columns: 1fr;
    }
  }
</style>
