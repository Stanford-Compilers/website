---
import PageLayout from '../layouts/PageLayout.astro';
import SoftwareCard from '../components/software/SoftwareCard.astro';
import { loadSoftware } from '../lib/collections';
import { SOFTWARE_CATEGORIES, SOFTWARE_CATEGORY_KEYS } from '../lib/taxonomy';

const software = await loadSoftware();
const byCategory = SOFTWARE_CATEGORY_KEYS.map((key) => ({
  key,
  meta: SOFTWARE_CATEGORIES[key],
  items: software.filter((s) => s.category === key),
})).filter((group) => group.items.length > 0);

const jsonld = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: 'Software',
  description: 'Compilers, languages, and libraries built by the Stanford Compilers Lab.',
  hasPart: software.map((s) => ({
    '@type': 'SoftwareSourceCode',
    name: s.name,
    description: s.summary,
    ...(s.links.repo ? { codeRepository: s.links.repo } : {}),
  })),
};
---

<PageLayout
  title="Software"
  kicker="Software"
  image="/og/software.png"
  lead="The group's research ships as software: compilers, languages, and libraries. Together they form a connected line of work on making computation portable across data representations and machines."
  description="Compilers, languages, and libraries built by the Stanford Compilers Lab — from the TACO tensor algebra compiler to meta-compilers, distributed runtimes, and accelerator toolchains."
  jsonld={jsonld}
>
  <div class="section">
    <div class="container container--wide sw-page">
      {
        byCategory.map((group) => (
          <section class="sw-cat" aria-labelledby={`cat-${group.key}`}>
            <div class="sw-cat__head">
              <h2 class="sw-cat__title" id={`cat-${group.key}`}>
                {group.meta.label}
              </h2>
              <p class="sw-cat__blurb muted">{group.meta.blurb}</p>
            </div>
            <ul class="sw-cat__grid">
              {group.items.map((s) => (
                <li>
                  <SoftwareCard software={s} headingLevel={3} />
                </li>
              ))}
            </ul>
          </section>
        ))
      }
    </div>
  </div>
</PageLayout>

<style>
  .sw-page {
    display: flex;
    flex-direction: column;
    gap: var(--space-2xl);
  }
  .sw-cat__head {
    margin-bottom: var(--space-l);
    max-width: 60ch;
  }
  .sw-cat__title {
    font-size: var(--step-2);
    display: flex;
    align-items: baseline;
    gap: 0.7rem;
  }
  .sw-cat__title::before {
    content: '';
    flex: none;
    width: 10px;
    height: 10px;
    background: var(--accent);
    transform: rotate(45deg);
    align-self: center;
  }
  .sw-cat__blurb {
    margin-top: var(--space-2xs);
    font-size: var(--step-0);
  }
  .sw-cat__grid {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(19rem, 1fr));
    gap: var(--space-s);
  }
  @media (max-width: 40rem) {
    .sw-cat__grid {
      grid-template-columns: 1fr;
    }
  }
</style>
