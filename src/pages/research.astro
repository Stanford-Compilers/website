---
import PageLayout from '../layouts/PageLayout.astro';
import TransformStack from '../components/research/TransformStack.astro';
import SectionHead from '../components/ui/SectionHead.astro';
import Icon from '../components/ui/Icon.astro';
import Button from '../components/ui/Button.astro';
import { loadFeaturedSoftware } from '../lib/collections';
import { TOPICS, TOPIC_KEYS } from '../lib/taxonomy';

const featured = await loadFeaturedSoftware(4);

// Order topics for the research areas grid (broad themes first).
const areaOrder = [
  'sparse-tensor-algebra',
  'array-programming',
  'compiler-ir',
  'meta-compilation',
  'distributed',
  'accelerators',
  'dsl',
  'autoscheduling',
  'recurrences',
  'relational',
] as const;
const areas = areaOrder
  .filter((k) => TOPIC_KEYS.includes(k))
  .map((k) => ({ key: k, ...TOPICS[k] }));
---

<PageLayout
  title="Research"
  kicker="Research"
  lead="We study a single question: how can one high-level program stay correct and fast while the data it works on and the machine it runs on keep changing?"
  description="The research narrative of the Kjolstad Lab: decoupling computation from representation and target, the compiler stack that makes it possible, and the systems that demonstrate it."
>
  {/* The problem */}
  <section class="section">
    <div class="container container--wide research-two">
      <div class="research-two__head">
        <p class="kicker" id="representation">The problem</p>
        <h2 class="research-two__title">Computation is written once. It has to run everywhere.</h2>
      </div>
      <div class="research-two__body flow">
        <p>
          A matrix multiply, a graph traversal, a physical simulation — each is easy to state at a
          high level. But making it <em>fast</em> forces a cascade of decisions: how is the data stored,
          dense or sparse and in which format? How is the work tiled and ordered? Does it run on a CPU,
          a GPU, an accelerator, or a cluster?
        </p>
        <p>
          Today those decisions are usually baked into the program. Change the data format or the
          hardware, and much of the code has to be rewritten. That is expensive, and it is why so
          much high-performance software is narrow and brittle.
        </p>
        <p>
          Our work is about breaking that coupling — separating <em>what</em> a program computes from
          <em>how</em> its data is represented and <em>where</em> it runs, and building compilers that
          fill in the rest.
        </p>
      </div>
    </div>
  </section>

  {/* The stack */}
  <section class="section band">
    <div class="container container--wide">
      <SectionHead
        kicker="The approach"
        title="One computation, lowered through a stack of decisions"
        description="Each layer fixes one more decision. Because the layers are separate, a change at the bottom — a new format, a new machine — does not require rewriting the top."
      />
      <div class="research-stack">
        <TransformStack />
      </div>
    </div>
  </section>

  {/* Research areas */}
  <section class="section" aria-labelledby="areas-title">
    <div class="container container--wide">
      <SectionHead
        kicker="Research areas"
        title="Where the work happens"
        id="areas-title"
        description="These threads all serve the same goal. Follow any one into the publications that develop it."
      />
      <ul class="areas">
        {
          areas.map((area) => (
            <li class="area">
              <a href={`/publications?topic=${area.key}`} class="area__link">
                <h3 class="area__title">{area.label}</h3>
                <p class="area__blurb">{area.blurb}</p>
                <span class="area__more mono">
                  Papers <Icon name="arrow-right" size={13} />
                </span>
              </a>
            </li>
          ))
        }
      </ul>
    </div>
  </section>

  {/* Machines + meta */}
  <section class="section band">
    <div class="container container--wide research-pillars">
      <div class="pillar" id="machines">
        <span class="pillar__icon"><Icon name="compass" size={24} /></span>
        <h2 class="pillar__title">From one program to many machines</h2>
        <p class="pillar__text muted">
          The same computation should reach CPUs, GPUs, accelerators, and distributed clusters. We
          express the mapping to hardware as explicit, separate schedules — data distribution apart
          from computation distribution — so targeting new hardware means writing a schedule, not a
          new program. This runs from distributed tensor algebra through to co-designed dataflow
          accelerators.
        </p>
        <a href="/publications?topic=distributed" class="pillar__link"
          >Distributed &amp; accelerator work <Icon name="arrow-right" size={14} /></a
        >
      </div>
      <div class="pillar" id="meta">
        <span class="pillar__icon"><Icon name="chip" size={24} /></span>
        <h2 class="pillar__title">Compilers that generate compilers</h2>
        <p class="pillar__text muted">
          If writing a compiler by hand is expensive, generate it. We build meta-compilers, fast
          baseline JITs, and virtual-machine generators — technology like Copy-and-Patch and Deegen
          that derives high-performance compilers and interpreters from a description instead of
          hand-written code.
        </p>
        <a href="/publications?topic=meta-compilation" class="pillar__link"
          >Meta-compilation work <Icon name="arrow-right" size={14} /></a
        >
      </div>
    </div>
  </section>

  {/* Systems as examples */}
  <section class="section" aria-labelledby="systems-title">
    <div class="container container--wide">
      <SectionHead
        kicker="In practice"
        title="Systems that carry the ideas"
        id="systems-title"
        href="/software"
        linkLabel="All software"
        description="The research is concrete: it ships as compilers, languages, and libraries you can read and run."
      />
      <ul class="systems">
        {
          featured.map((s) => (
            <li class="system">
              <a href={`/software/${s.id}`} class="system__link">
                <span class="system__name">{s.name}</span>
                <span class="system__summary">{s.summary}</span>
              </a>
            </li>
          ))
        }
      </ul>
    </div>
  </section>

  {/* Methodology */}
  <section class="section band">
    <div class="container container--narrow methodology flow">
      <p class="kicker">How we work</p>
      <h2 class="methodology__title">We build the systems, then find the abstraction</h2>
      <p class="muted">
        The group's results tend to come as working systems — compilers, languages, and simulators
        that run real workloads — alongside the abstractions that make them general. Papers are
        accompanied by artifacts and open-source releases, and the work spans the full stack, from
        formal intermediate representations down to co-designed hardware.
      </p>
      <p class="muted">
        Much of it is done with collaborators across programming languages, systems, computer
        architecture, and graphics, both at Stanford and elsewhere.
      </p>
    </div>
  </section>

  {/* CTA */}
  <section class="section">
    <div class="container container--narrow research-cta">
      <h2 class="research-cta__title">Read further</h2>
      <div class="research-cta__actions">
        <Button href="/publications" variant="primary" iconRight="arrow-right"
          >Browse publications</Button
        >
        <Button href="/software" variant="outline">Explore the software</Button>
        <Button href="/join" variant="ghost">Join the group</Button>
      </div>
    </div>
  </section>
</PageLayout>

<style>
  .research-two {
    display: grid;
    grid-template-columns: 1fr 1.4fr;
    gap: var(--space-2xl);
    align-items: start;
  }
  .research-two__title {
    font-size: var(--step-3);
    margin-top: var(--space-s);
    max-width: 15ch;
  }
  .research-two__body {
    font-size: var(--step-1);
  }
  .research-two__body em {
    font-style: italic;
    color: var(--ink);
  }
  .band {
    background: var(--paper-2);
    border-block: 1px solid var(--line-hairline);
  }
  .research-stack {
    max-width: 60rem;
  }

  .areas {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(16rem, 1fr));
    gap: var(--space-s);
  }
  .area__link {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    height: 100%;
    padding: var(--space-m);
    border: 1px solid var(--line);
    border-radius: var(--radius-m);
    background: var(--surface);
    text-decoration: none;
    color: inherit;
    transition:
      border-color var(--dur-2) var(--ease),
      transform var(--dur-2) var(--ease);
  }
  .area__link:hover {
    border-color: var(--accent);
    transform: translateY(-2px);
  }
  .area__title {
    font-size: var(--step-0);
    font-family: var(--font-sans);
    font-weight: 600;
    letter-spacing: 0;
  }
  .area__blurb {
    color: var(--ink-muted);
    font-size: var(--step--1);
    line-height: 1.5;
    flex: 1;
  }
  .area__more {
    display: inline-flex;
    align-items: center;
    gap: 0.4ch;
    font-size: var(--step--2);
    color: var(--ink-subtle);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
  .area__link:hover .area__more {
    color: var(--accent);
  }

  .research-pillars {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-2xl);
  }
  .pillar__icon {
    display: inline-flex;
    color: var(--tech);
    margin-bottom: var(--space-s);
  }
  .pillar__title {
    font-size: var(--step-2);
    max-width: 18ch;
  }
  .pillar__text {
    margin-top: var(--space-s);
    max-width: 52ch;
  }
  .pillar__link {
    display: inline-flex;
    align-items: center;
    gap: 0.4ch;
    margin-top: var(--space-m);
    font-weight: 600;
    color: var(--accent);
    text-decoration: none;
    font-size: var(--step--1);
  }

  .systems {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-s);
  }
  .system__link {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
    padding: var(--space-m);
    border-left: 2px solid var(--accent);
    background: var(--surface);
    border-radius: 0 var(--radius-s) var(--radius-s) 0;
    text-decoration: none;
  }
  .system__link:hover {
    background: var(--surface-2);
  }
  .system__name {
    font-family: var(--font-display);
    font-size: var(--step-1);
    color: var(--ink);
  }
  .system__summary {
    color: var(--ink-muted);
    font-size: var(--step--1);
  }

  .methodology__title {
    font-size: var(--step-3);
    margin-top: var(--space-s);
  }
  .research-cta {
    text-align: center;
  }
  .research-cta__title {
    font-size: var(--step-2);
  }
  .research-cta__actions {
    margin-top: var(--space-l);
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-s);
    justify-content: center;
  }

  @media (max-width: 56rem) {
    .research-two,
    .research-pillars {
      grid-template-columns: 1fr;
      gap: var(--space-l);
    }
    .systems {
      grid-template-columns: 1fr;
    }
  }
</style>
